# Frontend (Vite) — copiar a .env.local para desarrollo
# IMPORTANTE: incluir https://. Sin protocolo el navegador arma URLs rotas (intercambius.com.ar/api → /intercambius.com.ar/api).
VITE_API_URL=https://intercambios-backend.vercel.app

# Dejar vacío = mapas con OpenStreetMap (Leaflet). Solo poner key cuando Maps JS + Places + Geocoding estén activos en Google Cloud.
VITE_GOOGLE_MAPS_API_KEY=
# VITE_USE_GOOGLE_MAPS=false

# Google Sign-In — cliente Web 725093... (proyecto composed-arch)
# Mismo Client ID que GOOGLE_OAUTH_CLIENT_ID en el backend.
# Redirect URI en Google Cloud: https://intercambius.com.ar/auth/google/callback
VITE_GOOGLE_CLIENT_ID=

# reCAPTCHA v2 (checkbox)
VITE_RECAPTCHA_SITE_KEY=
